# Copy this file to .env and fill in real values

PORT=4000

# Allowed browser origins for CORS. Comma-separate multiple values.
#   Dev:     http://localhost:3000
#   Prod:    https://glinte.in,https://www.glinte.in
FRONTEND_ORIGIN=http://localhost:3000

# JWT — generate any long random string
JWT_SECRET=replace-this-with-a-long-random-string

# Storage backend.
#   • Leave MONGODB_URI blank → uses backend/data/*.json (good for first-run dev).
#   • Set MONGODB_URI         → uses MongoDB Atlas. Products auto-seed from
#     data/products.json the first time the products collection is empty.
# Get the URI from MongoDB Atlas → Database → Connect → Drivers.
# It looks like:
#   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/glinte?retryWrites=true&w=majority
MONGODB_URI=

# Razorpay (Test Mode is fine — get from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Shiprocket (https://app.shiprocket.in/api-user)
SHIPROCKET_EMAIL=you@example.com
SHIPROCKET_PASSWORD=your-shiprocket-api-password
# Pickup location nickname you set up in Shiprocket → Settings → Pickup Addresses
SHIPROCKET_PICKUP_LOCATION=Primary

# Default admin (created on first server start if no users exist)
SEED_ADMIN_EMAIL=admin@glinte.in
SEED_ADMIN_PASSWORD=admin123
