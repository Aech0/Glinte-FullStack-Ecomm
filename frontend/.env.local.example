# Copy this to .env.local

NEXT_PUBLIC_API_URL=http://localhost:4000

# Public Razorpay key — same KEY_ID as backend, never the secret.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Canonical site URL — used in OG meta, sitemap, robots. Set this to the
# live origin (e.g. https://glinte.in) in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
